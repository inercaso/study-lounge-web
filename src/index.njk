---
title: Study Lounge
---
<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
<link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Google+Sans+Display:wght@700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="reset.css" />
<link rel="stylesheet" href="style.css" />
</head>
<body>

<nav>
  <div class="inner">
    <div class="brand">
      <div class="logo-circle"><img src="assets/svg/studylounge.svg" alt="{{ nav.brand }}"></div>
      {{ nav.brand }}
      <input type="checkbox" id="nav-toggle" class="nav-toggle">
    </div>
    <label for="nav-toggle" class="hamburger">&#9776;</label>
    <ul class="nav-links">
      {% for link in nav.links %}
      <li><a href="{{ link.href }}"{% if link.active %} class="active"{% endif %}>{{ link.text }}</a></li>
      {% endfor %}
    </ul>
  </div>
</nav>

<section class="hero">
  <div class="inner">
    <div class="hero-grid">
      <img class="hero-img" src="{{ hero.image }}" alt="{{ hero.image_alt }}">
      <div class="hero-right">
        <h1>{{ hero.heading_line1 }}<br><span class="hl">{{ hero.heading_highlight }}</span>{{ hero.heading_line2 }}</h1>
        <p class="tagline">{{ hero.tagline }}</p>
        <p class="desc">{{ hero.description }}</p>
        <div class="btn-row">
          <a href="{{ hero.cta_primary_href }}" class="btn-primary">{{ hero.cta_primary_text }}</a>
          <a href="{{ hero.cta_secondary_href }}" class="btn-outline">{{ hero.cta_secondary_text }}</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="de-ce-noi" class="why-section">
  <div class="inner">
    <div class="why-layout">
      <div class="why-left">
        <div class="why-heading"><span class="why-heading-text">{{ whyus.heading_stats }}</span></div>
        <div class="why-icons-stack">
          <div class="bubble">
            <div class="avatar-icons">
              <div class="avatar-icon"></div>
              <div class="avatar-icon"></div>
              <div class="avatar-icon"></div>
            </div>
            {{ whyus.stat_students }}
          </div>
          <div class="why-stat-row">
            <div class="why-logo-float"><img src="assets/svg/studylounge.svg" alt="{{ nav.brand }}"></div>
            <div class="bubble">{{ whyus.stat_experience }}</div>
          </div>
        </div>
      </div>
      <div class="why-offerings">
        <div class="why-heading"><span class="why-heading-text">{{ whyus.heading_offerings }}</span></div>
        <div class="why-list-wrap">
          <div class="why-green-bar"></div>
          <ul>
            {% for item in whyus.offerings %}
            <li>{{ item }}</li>
            {% endfor %}
          </ul>
        </div>
      </div>
      <img class="why-image" src="{{ whyus.image }}" alt="{{ whyus.image_alt }}">
    </div>
  </div>
</section>

<section class="stats-section">
  <div class="inner">
    <div class="stat-item">
      <div class="stat-num">{{ stats.stat1_number }}</div>
      <div class="stat-label">{{ stats.stat1_label }}</div>
    </div>
    <div class="vdivider"></div>
    <div class="stat-item">
      <div class="stat-num">{{ stats.stat2_number }}</div>
      <div class="stat-label">{{ stats.stat2_label }}</div>
    </div>
    <div class="vdivider"></div>
    <div class="stat-desc">{{ stats.description }}</div>
  </div>
</section>

<section id="cursuri" class="courses-section">
  <div class="inner">
    <span class="pill">{{ courses.section_pill }}</span>
    <h2>{{ courses.section_heading }}</h2>
    <div class="courses-grid">
      {% for course in courses.items %}
      <div class="course-card">
        <img class="course-img" src="{{ course.image }}" alt="{{ course.image_alt }}">
        <div class="course-info">
          <div class="course-tag">{{ course.tag }}</div>
          <div class="course-name">{{ course.name }}</div>
          <div class="course-sub">{{ course.subtitle }}</div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

</body>
</html>
